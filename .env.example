PORT=3000
JWT_SECRET=replace-with-a-long-random-secret

# json or mysql
STORAGE_DRIVER=json

# Required only when STORAGE_DRIVER=mysql
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=iot_mall
MYSQL_USER=replace_me
MYSQL_PASSWORD=replace_me

ADMIN_PHONE=17724888898
ADMIN_USERNAME=admin
# Set this before first production start. If omitted, the app will generate
# a one-time password for the initial admin and print it in the server log.
ADMIN_PASSWORD=

# EMS 客户 API 开放平台
# prod 或 sandbox
EMS_API_ENV=prod
EMS_OPEN_URL=https://api.ems.com.cn/amp-prod-api/f/amp/api/open
EMS_TEST_URL=https://api.ems.com.cn/amp-prod-api/f/amp/api/test
EMS_SENDER_NO=
EMS_AUTHORIZATION=
# 若平台单独提供“签名钥匙/加密钥匙”，填写这里；未提供时可留空并沿用 EMS_AUTHORIZATION
EMS_SIGN_KEY=
EMS_USER_CODE=
EMS_MSG_TYPE=0
EMS_VERSION=V1.0.0

# 默认建单参数
EMS_BIZ_PRODUCT_NO=10
EMS_BIZ_PRODUCT_ID=
EMS_CONTENTS_ATTRIBUTE=3
EMS_DEFAULT_WEIGHT_GRAMS=500
EMS_LABEL_TYPE=129

# 默认寄件人信息，未配置时会优先回退到后台店铺设置里的寄件地址
EMS_SENDER_NAME=
EMS_SENDER_PHONE=
EMS_SENDER_POST_CODE=
EMS_SENDER_PROV=
EMS_SENDER_CITY=
EMS_SENDER_COUNTY=
EMS_SENDER_ADDRESS=

# 打印模式
# browser: 浏览器打开面单后手动打印
# powershell: Windows 本机尝试直接调用系统打印
EMS_PRINT_MODE=browser
EMS_PRINTER_NAME=
# 可选，自定义打印命令，支持 {file} {printer} 占位符
EMS_PRINT_COMMAND=
